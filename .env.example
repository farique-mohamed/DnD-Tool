# Database connection string for Prisma
DATABASE_URL="postgresql://postgres:your-secure-password-here@localhost:5999/dndtool"

# Docker Compose variables (used by docker-compose.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=dndtool

# JWT signing secret — change this to a long random string in production
JWT_SECRET=your-super-secret-jwt-key-change-in-production
