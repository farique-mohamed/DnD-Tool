// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

enum UserRole {
  PLAYER
  DUNGEON_MASTER
  ADMIN
}

enum DmRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AdventurePlayerStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum EncounterParticipantType {
  PLAYER
  MONSTER
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model User {
  id         String      @id @default(cuid())
  username   String      @unique
  password   String
  role       UserRole    @default(PLAYER)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  dmRequests DmRequest[]
  diceRolls  DiceRoll[]
  characters Character[]
  adventures       Adventure[]
  adventurePlayers AdventurePlayer[]
  dmNotesSent      DmNote[]          @relation("dmNotesSent")
  dmNotesReceived  DmNote[]          @relation("dmNotesReceived")
  sessionNotes     SessionNote[]
  inventoryItemsAdded CharacterInventoryItem[] @relation("inventoryItemsAdded")
  playerSpellsAssigned AdventurePlayerSpell[] @relation("playerSpellsAssigned")
  familiarsAssigned AdventurePlayerFamiliar[] @relation("familiarsAssigned")
  encounterTemplates  EncounterTemplate[]

  @@map("users")
}

model DiceRoll {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  username    String
  diceType    String
  result      Int
  label       String  @default("General")
  rollMode    String  @default("NORMAL")
  adventureId String?
  rolledAt    DateTime @default(now())

  @@map("dice_rolls")
}

model DmRequest {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  status      DmRequestStatus @default(PENDING)
  requestedAt DateTime        @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?

  @@map("dm_requests")
}

model Item {
  id          String   @id @default(cuid())
  name        String
  description String?
  isMagical   Boolean  @default(false)
  rarity      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("items")
}

model Character {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])

  // Basic info
  name         String
  race         String
  characterClass String
  rulesSource  String   @default("PHB")
  level        Int      @default(1)
  alignment    String   @default("True Neutral")
  background   String?
  backstory    String?
  languages    String  @default("[]")               // JSON: string[] of known language names

  // Ability scores (standard D&D 5e: 1–20)
  strength     Int      @default(10)
  dexterity    Int      @default(10)
  constitution Int      @default(10)
  intelligence Int      @default(10)
  wisdom       Int      @default(10)
  charisma     Int      @default(10)

  // Derived combat stats
  maxHp        Int      @default(10)
  currentHp    Int      @default(10)
  tempHp       Int      @default(0)
  armorClass   Int      @default(10)
  speed        Int      @default(30)

  // Character progression
  subclass           String?
  spellSlotsUsed     String  @default("[]")          // JSON: number[] (used per slot level 1-9)
  skillProficiencies String  @default("[]")           // JSON: string[] of proficient skill names
  skillExpertise     String  @default("[]")           // JSON: string[] of skill names with expertise (double proficiency)
  preparedSpells     String  @default("[]")           // JSON: string[] of prepared/known spell names
  featureUses        String  @default("{}")           // JSON: Record<string, number> feature name → used count
  activeConditions    String  @default("[]")           // JSON: string[] of active condition/status names
  activeDiseases      String  @default("[]")           // JSON: string[] of active disease names
  feats              String  @default("[]")           // JSON: string[] of taken feat names
  notes              String  @default("")             // Free-text notes for the character
  levelUpSelections  String  @default("{}")           // JSON: Record<string, string[]> — fighting styles, tool profs, metamagic, invocations, etc.
  equippedItems      String  @default("{\"mainHand\":null,\"offHand\":null,\"armor\":null,\"shield\":null}") // JSON: EquippedItems

  adventurePlayers AdventurePlayer[]
  dmNotes          DmNote[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("characters")
}

model Adventure {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  name       String
  source     String
  inviteCode String   @unique @default(cuid())
  monsters   AdventureMonster[]
  items      AdventureItem[]
  spells     AdventureSpell[]
  npcs       AdventureNpc[]
  players    AdventurePlayer[]
  encounter    Encounter?
  dmNotes      DmNote[]
  sessionNotes SessionNote[]
  sessions     AdventureSession[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("adventures")
}

model AdventureMonster {
  id          String    @id @default(cuid())
  adventureId String
  adventure   Adventure @relation(fields: [adventureId], references: [id])
  name        String
  source      String
  createdAt   DateTime  @default(now())

  @@unique([adventureId, name, source])
  @@map("adventure_monsters")
}

model AdventureItem {
  id          String    @id @default(cuid())
  adventureId String
  adventure   Adventure @relation(fields: [adventureId], references: [id])
  name        String
  source      String
  createdAt   DateTime  @default(now())

  @@unique([adventureId, name, source])
  @@map("adventure_items")
}

model AdventureSpell {
  id          String    @id @default(cuid())
  adventureId String
  adventure   Adventure @relation(fields: [adventureId], references: [id])
  name        String
  source      String
  createdAt   DateTime  @default(now())

  @@unique([adventureId, name, source])
  @@map("adventure_spells")
}

model AdventurePlayer {
  id          String                @id @default(cuid())
  adventureId String
  adventure   Adventure             @relation(fields: [adventureId], references: [id])
  userId      String
  user        User                  @relation(fields: [userId], references: [id])
  characterId String
  character   Character             @relation(fields: [characterId], references: [id])
  status      AdventurePlayerStatus @default(PENDING)
  playerNote  String                @default("")  // Player's note to the DM
  joinedAt    DateTime              @default(now())
  resolvedAt  DateTime?

  inventoryItems CharacterInventoryItem[]
  spells         AdventurePlayerSpell[]
  familiars      AdventurePlayerFamiliar[]
  encounterParticipants EncounterParticipant[]

  @@unique([adventureId, userId])
  @@map("adventure_players")
}

model DmNote {
  id          String    @id @default(cuid())
  adventureId String
  adventure   Adventure @relation(fields: [adventureId], references: [id])
  fromUserId  String
  fromUser    User      @relation("dmNotesSent", fields: [fromUserId], references: [id])
  toUserId    String
  toUser      User      @relation("dmNotesReceived", fields: [toUserId], references: [id])
  characterId String
  character   Character @relation(fields: [characterId], references: [id])
  content     String
  reaction       String?
  reactionReadAt DateTime?
  readAt         DateTime?
  createdAt   DateTime  @default(now())

  @@map("dm_notes")
}

model SessionNote {
  id          String    @id @default(cuid())
  adventureId String
  adventure   Adventure @relation(fields: [adventureId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  title       String
  content     String    @default("")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("session_notes")
}

model CharacterInventoryItem {
  id                String          @id @default(cuid())
  adventurePlayerId String
  adventurePlayer   AdventurePlayer @relation(fields: [adventurePlayerId], references: [id])
  itemName          String
  itemSource        String
  quantity          Int             @default(1)
  isStartingItem    Boolean         @default(false)
  customDescription String?
  addedByUserId     String
  addedByUser       User            @relation("inventoryItemsAdded", fields: [addedByUserId], references: [id])
  createdAt         DateTime        @default(now())

  @@unique([adventurePlayerId, itemName, itemSource])
  @@map("character_inventory_items")
}

model AdventurePlayerSpell {
  id                String          @id @default(cuid())
  adventurePlayerId String
  adventurePlayer   AdventurePlayer @relation(fields: [adventurePlayerId], references: [id])
  spellName         String
  spellSource       String
  assignedByUserId  String
  assignedByUser    User            @relation("playerSpellsAssigned", fields: [assignedByUserId], references: [id])
  createdAt         DateTime        @default(now())

  @@unique([adventurePlayerId, spellName, spellSource])
  @@map("adventure_player_spells")
}

model Encounter {
  id                String   @id @default(cuid())
  adventureId       String   @unique
  adventure         Adventure @relation(fields: [adventureId], references: [id])
  currentTurnIndex  Int      @default(0)
  round             Int      @default(1)
  privateDeathSaves Boolean  @default(false)
  participants      EncounterParticipant[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("encounters")
}

model EncounterParticipant {
  id                String                    @id @default(cuid())
  encounterId       String
  encounter         Encounter                 @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  type              EncounterParticipantType
  initiativeRoll    Int
  sortOrder         Int                       @default(0)

  // Player fields (only set for PLAYER type)
  adventurePlayerId String?
  adventurePlayer   AdventurePlayer?          @relation(fields: [adventurePlayerId], references: [id])

  // Monster fields (only set for MONSTER type)
  name              String?
  originalName      String?           // Original monster name for stat block lookup (preserved on rename)
  monsterSource     String?
  maxHp             Int?
  currentHp         Int?
  tempHp            Int                       @default(0)
  armorClass        Int?

  // Shared combat fields
  conditions        String                    @default("[]")  // JSON: string[] of active condition names
  deathSaveSuccesses Int                      @default(0)
  deathSaveFailures  Int                      @default(0)
  isActive          Boolean                   @default(true)

  createdAt         DateTime                  @default(now())

  @@map("encounter_participants")
}

model EncounterTemplate {
  id           String                        @id @default(cuid())
  userId       String
  user         User                          @relation(fields: [userId], references: [id])
  name         String
  description  String?
  participants EncounterTemplateParticipant[]
  createdAt    DateTime                      @default(now())
  updatedAt    DateTime                      @updatedAt

  @@map("encounter_templates")
}

model EncounterTemplateParticipant {
  id                 String             @id @default(cuid())
  templateId         String
  template           EncounterTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name               String
  monsterSource      String
  maxHp              Int
  armorClass         Int
  initiativeModifier Int?
  sortOrder          Int                @default(0)
  createdAt          DateTime           @default(now())

  @@map("encounter_template_participants")
}

model AdventurePlayerFamiliar {
  id                String          @id @default(cuid())
  adventurePlayerId String
  adventurePlayer   AdventurePlayer @relation(fields: [adventurePlayerId], references: [id])
  monsterName       String          // Original monster name for stat block lookup
  displayName       String          // Custom name (e.g., "Shadow" for a cat familiar)
  monsterSource     String          // Source book code for lookup
  notes             String          @default("")  // DM notes about this familiar
  assignedByUserId  String
  assignedByUser    User            @relation("familiarsAssigned", fields: [assignedByUserId], references: [id])
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([adventurePlayerId, displayName])
  @@map("adventure_player_familiars")
}

model AdventureNpc {
  id               String   @id @default(cuid())
  adventureId      String
  adventure        Adventure @relation(fields: [adventureId], references: [id])
  name             String
  race             String
  gender           String
  alignment        String
  occupation       String
  personalityTraits String  @default("[]")   // JSON string[]
  appearance       String   @default("")
  voiceMannerism   String   @default("")
  background       String   @default("")     // backstory/background info
  motivation       String   @default("")     // what drives this NPC
  secret           String   @default("")     // hidden info only DM knows
  notes            String   @default("")     // free-text DM notes
  location         String   @default("")     // "Found in" location field
  isVisible        Boolean  @default(false)  // false = hidden from players, true = visible
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("adventure_npcs")
}

model AdventureSession {
  id          String        @id @default(cuid())
  adventureId String
  adventure   Adventure     @relation(fields: [adventureId], references: [id])
  title       String
  description String?
  scheduledAt DateTime
  duration    Int?
  location    String?
  status      SessionStatus @default(SCHEDULED)
  inGameDate  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("adventure_sessions")
}
